{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/cleanink-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "Default": "Host=postgres;Port=5432;Database=cleanink_oncall;Username=cleanink;Password=cleanink_pass"
  },
  "Jwt": {
    "Issuer": "CleanInkOnCall",
    "Audience": "CleanInkOnCallClients",
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_USE_ENV_VAR_OR_SECRETS_MANAGER",
    "ExpiryMinutes": 60
  },
  "Claude": {
    "ApiKey": "CHANGE_ME",
    "Model": "claude-3-5-sonnet-20241022",
    "BaseUrl": "https://api.anthropic.com",
    "MaxTokens": 4096
  },
  "AzureOpenAI": {
    "ApiKey": "CHANGE_ME",
    "Endpoint": "https://YOUR-RESOURCE.openai.azure.com",
    "DeploymentName": "gpt-4o",
    "ApiVersion": "2024-02-01",
    "MaxTokens": 4096
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
