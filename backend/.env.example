# ─────────────────────────────────────────────────────────────────────────────
# CleanInk OnCall — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# Ne JAMAIS committer le fichier .env (voir .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données ───────────────────────────────────────────────────────────
# Mot de passe fort : openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Clé aléatoire min. 32 chars : openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET

# ── Domaines (prod) ───────────────────────────────────────────────────────────
# Nom de domaine de l'API (ex: api.cleanink.fr)
API_HOST=api.localhost

# Email pour Let's Encrypt (prod uniquement)
ACME_EMAIL=ssl@cleanink.fr

# ── IA (optionnel) ────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
